- name: epy_block_0
  id: epy_block
  parameters:
    _source_code: "\"\"\"\nEmbedded Python Blocks:\n\nEach time this file is saved,\
      \ GRC will instantiate the first class it finds\nto get ports and parameters\
      \ of your block. The arguments to __init__  will\nbe the parameters. All of\
      \ them are required to have default values!\n\"\"\"\n\nimport numpy as np\n\
      from gnuradio import gr\n\ndef encode(str): \n    bits = ''.join(format(ord(char),\
      \ '08b') for char in str)\n    print(f\"Encoded message: {bits}\")\n    return\
      \ bits\n\nclass blk(gr.sync_block):  \n    \"\"\"Take a string message and output\
      \ it as a stream of bytes.\"\"\"\n\n    def __init__(self, message=\"Hello,\
      \ World!\"): \n        gr.sync_block.__init__(\n            self,\n        \
      \    name='String to Bits',  \n            in_sig=[],\n            out_sig=[np.int8]\n\
      \        )\n\n        self.message = message\n\n    def work(self, input_items,\
      \ output_items):        \n        output_items[0][:] = [int(bit) for bit in\
      \ encode(self.message)]\n\n        return len(output_items[0])\n"
    affinity: ''
    alias: ''
    comment: ''
    maxoutbuf: '0'
    message: '''Hello, World!'''
    minoutbuf: '0'
  states:
    _io_cache: ('String to Bits', 'blk', [('message', "'Hello, World!'")], [], [('0',
      'byte', 1)], 'Take a string message and output it as a stream of bytes.', ['message'])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [168, 360.0]
    rotation: 0
    state: enabled
